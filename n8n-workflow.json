            {
              "name": "messages",
              "value": "={{ [{\"role\": \"user\", \"content\": \"You are a social media content creator. Based on this news article, generate a JSON response with exactly these fields: 1. teaser: exactly 1-2 sentences that hook the reader for a Facebook post. 2. summary: 3-4 sentences describing the full news story. 3. tags: 5 relevant hashtags as a single string. 4. image_prompt: a detailed prompt to generate an image that represents this story. Return ONLY valid JSON, no other text. Article title: \" + $json.title + \" Article content: \" + $('HTML').item.json.text}] }}"
            }
