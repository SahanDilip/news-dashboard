    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiContent = $input.item.json.choices[0].message.content;\nconst clean = aiContent.replace(/```json|```/g, '').trim();\nconst parsed = JSON.parse(clean);\n\n// Get original news item data\nconst originalItem = $('Code in JavaScript2').item.json;\n\nreturn {\n  json: {\n    source_url: originalItem.link,\n    article_title: originalItem.title,\n    source_site: originalItem.source_site || 'unknown',\n    published_at: originalItem.isoDate,\n    teaser: parsed.teaser,\n    summary: parsed.summary,\n    tags: parsed.tags,\n    image_prompt: parsed.image_prompt,\n    status: 'new'\n  }\n};"
      },
