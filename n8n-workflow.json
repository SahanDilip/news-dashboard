      "name": "Webhook",
      "webhookId": "70efa0b1-0042-4b15-aeac-c58daf64289e"
    },
    {
      "parameters": {
        "jsCode": "const feeds = [\n  { name: 'BBC', url: 'http://feeds.bbci.co.uk/news/rss.xml' },\n  { name: 'CNN', url: 'http://rss.cnn.com/rss/edition.rss' },\n  { name: 'Al Jazeera', url: 'https://www.aljazeera.com/xml/rss/all.xml' },\n  { name: 'The Guardian', url: 'https://www.theguardian.com/world/rss' }\n];\n\nreturn feeds.map(feed => ({ json: feed }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -672,
        176
      ],
      "id": "f38f02fc-9185-434f-8ec5-f19595484799",
      "name": "RSS List",
      "executeOnce": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "url": "={{ $json.url }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -528,
        176
      ],
      "id": "e3a01ae5-7f77-4ec7-a50f-1e02ce624e4d",
      "name": "Fetch RSS",
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const xml = item.json.data;\n  \n  if (!xml) continue;\n  \n  const itemMatches = xml.match(/<item>([\\s\\S]*?)<\\/item>/g) || [];\n\n  for (const entry of itemMatches.slice(0, 3)) {\n    const title = (\n      entry.match(/<title><!\\[CDATA\\[(.*?)\\]\\]><\\/title>/) ||\n      entry.match(/<title>(.*?)<\\/title>/)\n    )?.[1]?.trim() || '';\n\n    const link = (\n      entry.match(/<link>(.*?)<\\/link>/) || []\n    )?.[1]?.trim() || '';\n\n    const pubDate = (\n      entry.match(/<pubDate>(.*?)<\\/pubDate>/) || []\n    )?.[1]?.trim() || '';\n\n    const isoDate = pubDate\n      ? new Date(pubDate).toISOString()\n      : new Date().toISOString();\n\n    // Extract source site from URL\n    let sourceSite = 'Unknown';\n    if (link) {\n      const match = link.match(/^https?:\\/\\/[^\\/]+\\.[a-z]{2,6}/i);\n      sourceSite = match ? match[0] : 'Unknown';\n    }\n\n    if (title && link) {\n      results.push({ \n        json: { \n          title, \n          link, \n          pubDate, \n          isoDate, \n          source_site: sourceSite \n        } \n      });\n    }\n  }\n}\n\nif (results.length === 0) {\n  return [{ json: { error: 'No items found', inputCount: $input.all().length } }];\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -384,
        176
      ],
      "id": "40f046b2-1596-4e08-a6dc-075e06fabb38",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const dbRows = $('Get many rows').all();\nconst dbLinks = dbRows.map(row => row.json.link);\n\nreturn $('Code in JavaScript1').all().filter(item => {\n  return !dbLinks.includes(item.json.link);\n}).map(item => ({ json: item.json }));"
      },
      "type": "n8n-nodes-base.code",
